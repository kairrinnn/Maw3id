# Supabase — project URL and anon key (safe for browser; used in client-side auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-side only, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard password
ADMIN_PASSWORD=

# WhatsApp / Meta Cloud API
WEBHOOK_SECRET=
WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# LLM providers (only one needed at runtime — set the one in use)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Phase 5: shared secret between pg_cron and /api/reminders/send
# Must also be set in hosted Supabase via: ALTER DATABASE postgres SET app.cron_secret = '<value>';
CRON_SECRET=
