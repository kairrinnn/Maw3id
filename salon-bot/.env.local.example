# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta WhatsApp Cloud API
# Bearer token from Meta Developer Console > App > WhatsApp > API Setup
WHATSAPP_API_TOKEN=

# Pinned Meta Graph API version — do not change without testing
WHATSAPP_API_VERSION=v19.0

# App secret from Meta Developer Console > App > Settings > Basic
# Used to verify X-Hub-Signature-256 on every webhook POST
WHATSAPP_APP_SECRET=

# Random string set in Meta Developer Console > App > WhatsApp > Configuration > Webhook
WEBHOOK_VERIFY_TOKEN=

# Set to 'true' in local dev/test to skip webhook signature verification
# NEVER set in production
SKIP_WEBHOOK_SIGNATURE=true
